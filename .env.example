# Backend server port
PORT=8787

# Directory where Hunter stores JSON scan reports
DATA_DIR=./data

# Crawl defaults
SCAN_MAX_PAGES=50
SCAN_MAX_ASSETS=300

# Timeout controls (milliseconds)
REQUEST_TIMEOUT_MS=12000
PREVIEW_REQUEST_TIMEOUT_MS=12000
CRAWL_TIMEOUT_MS=300000
SCAN_TIMEOUT_MS=480000

# Live scan summary push interval to UI (milliseconds)
SCAN_PROGRESS_EVENT_INTERVAL_MS=500

# Allow scanning of self-signed certificate targets
ALLOW_INSECURE_TLS=true

# Optional: override browser-like user agents for target fetches
SCANNER_USER_AGENT=
PREVIEW_USER_AGENT=
# Optional: authorized session cookies for targets with bot/security checkpoints
SCANNER_COOKIE=
PREVIEW_COOKIE=

# Optional: built-in TCP port scan tuning (no external nmap binary required)
PORT_SCAN_TOP_PORTS=200
PORT_SCAN_TIMEOUT_MS=1200
PORT_SCAN_CONCURRENCY=24
# Comma-separated TCP ports; leave empty to use defaults in code
PORT_SCAN_PORTS=

# Optional: built-in port vulnerability checks on discovered open ports
PORT_VULN_SCAN_ENABLED=true
PORT_VULN_MAX_SERVICES=12
PORT_VULN_TIMEOUT_MS=1800
PORT_VULN_CONCURRENCY=4
